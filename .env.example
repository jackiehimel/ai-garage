# copy to .env locally (never commit .env). vercel: set same keys in project env.
# required for npm run sync:espresso unless site-config.json exists with espressoSourceRepo

GARAGE_ESPRESSO_REPO=your-org/ai-espresso

# optional full github url if not github.com/org/repo
# GARAGE_ESPRESSO_SOURCE_URL=https://github.com/your-org/ai-espresso

# optional mailto (or https:) shown in synced digest footer as "spot something off?"
# GARAGE_ESPRESSO_FEEDBACK_MAILTO=mailto:ai-garage-feedback@yourcompany.com?subject=Espresso%20issue
