{
  "name": "garage-portal",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "AI Garage Portal prototype with Playwright-driven visual verification.",
  "scripts": {
    "snap": "node scripts/snap.mjs",
    "snap:merged": "node scripts/snap.mjs --file ai_garage_portal_merged.html --full",
    "sync:espresso": "node scripts/sync-espresso-from-manifest.mjs --manifest-url https://raw.githubusercontent.com/jackiehimel/ai-espresso-finalized/main/editions/publish/latest.json",
    "install:browsers": "PLAYWRIGHT_BROWSERS_PATH=\"$HOME/.cache/ms-playwright\" playwright install chromium"
  },
  "devDependencies": {
    "playwright": "^1.48.0"
  }
}
